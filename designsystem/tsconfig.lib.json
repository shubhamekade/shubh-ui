{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "incremental": false,
    "noEmit": true,
    "jsx": "react-jsx",
    "plugins": []
  },
  "include": [
    "src/index.ts",
    "src/components/**/*.ts",
    "src/components/**/*.tsx",
    "src/hooks/**/*.ts",
    "src/hooks/**/*.tsx",
    "src/utils/**/*.ts",
    "src/utils/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "src/app/**",
    "src/layout/**",
    "**/*.test.ts",
    "**/*.test.tsx"
  ]
}
